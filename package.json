{
  "name": "@monorepo-erp/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "infra:up": "docker compose -f infra/docker-compose.yml up -d",
    "infra:down": "docker compose -f infra/docker-compose.yml down",
    "dev:api": "nx serve apps/api-web",
    "dev:worker": "nx serve apps/api-worker",
    "dev:spa": "nx serve spa",
    "dev": "nx run-many --target=serve --projects=apps/api-web,apps/api-inventory,spa --parallel",
    "test": "nx run-many --target=test --all",
    "test:e2e": "playwright test",
    "db:migrate": "mikro-orm migration:up",
    "db:seed": "mikro-orm seeder:run",
    "build": "nx run-many --target=build --all"
  },
  "private": true,
