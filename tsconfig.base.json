{
  "compilerOptions": {
    "rootDir": "src",
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "paths": {
      "@erp/database": ["./libs/database/src/index.ts"],
      "@erp/database/*": ["./libs/database/src/*"],
    },
    "customConditions": ["@monorepo-erp/source"]
  }
}
