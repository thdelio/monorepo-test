{
  "name": "@monorepo-erp/apps/api-cron-e2e",
  "version": "0.0.1",
  "private": true,
  "nx": {
    "name": "apps/api-cron-e2e",
    "implicitDependencies": [
      "apps/api-cron"
    ],
    "targets": {
      "e2e": {
        "executor": "@nx/jest:jest",
        "outputs": [
          "{projectRoot}/test-output/jest/coverage"
        ],
        "options": {
          "jestConfig": "apps/api-cron-e2e/jest.config.cts",
          "passWithNoTests": true
        },
        "dependsOn": [
          "apps/api-cron:build",
          "apps/api-cron:serve"
        ]
      }
    }
  }
}
